{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kazene.org/schemas/ai-search-trace-receipt.schema.json",
  "title": "AI Search Trace Receipt",
  "description": "A privacy-preserving trace receipt for AI-mediated search events.",
  "type": "object",
  "required": [
    "schema_version",
    "trace_id",
    "event_type",
    "timestamp_bucket",
    "sampling",
    "query_trace",
    "source_trace",
    "answer_trace",
    "privacy",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "trace_id": {
      "type": "string",
      "description": "A non-reversible identifier for this trace receipt.",
      "minLength": 8
    },
    "event_type": {
      "type": "string",
      "const": "ai_search_trace_receipt"
    },
    "timestamp_bucket": {
      "type": "string",
      "description": "A rounded timestamp bucket. This should not be a precise behavioral timestamp."
    },
    "sampling": {
      "type": "object",
      "required": [
        "sampled",
        "sampling_method"
      ],
      "properties": {
        "sampled": {
          "type": "boolean"
        },
        "sampling_method": {
          "type": "string",
          "enum": [
            "none",
            "random",
            "risk_based",
            "source_based",
            "user_opt_in",
            "audit_required"
          ]
        },
        "sampling_rate_hint": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "query_trace": {
      "type": "object",
      "required": [
        "query_fingerprint",
        "intent_code",
        "sensitivity_bucket"
      ],
      "properties": {
        "query_fingerprint": {
          "type": "string",
          "description": "A privacy-preserving semantic or cryptographic fingerprint of the query."
        },
        "intent_code": {
          "type": "string",
          "enum": [
            "general_question",
            "news_check",
            "technical_research",
            "academic_research",
            "product_comparison",
            "legal_policy_check",
            "medical_health_info",
            "creative_support",
            "code_research",
            "unknown"
          ]
        },
        "sensitivity_bucket": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "restricted",
            "unknown"
          ]
        }
      },
      "additionalProperties": false
    },
    "source_trace": {
      "type": "object",
      "required": [
        "source_count",
        "source_fingerprints",
        "citation_count"
      ],
      "properties": {
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_fingerprints": {
          "type": "array",
          "description": "Hashed or otherwise non-reversible source identifiers.",
          "items": {
            "type": "string"
          }
        },
        "citation_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_class_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "official",
              "documentation",
              "academic",
              "news",
              "repository",
              "blog",
              "forum",
              "database",
              "unknown"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "answer_trace": {
      "type": "object",
      "required": [
        "answer_digest",
        "confidence_bucket",
        "transformation_code"
      ],
      "properties": {
        "answer_digest": {
          "type": "string",
          "description": "A digest of the generated answer. The raw answer text must not be stored here."
        },
        "confidence_bucket": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unresolved"
          ]
        },
        "transformation_code": {
          "type": "string",
          "enum": [
            "direct_answer",
            "summary",
            "comparison",
            "synthesis",
            "translation",
            "extraction",
            "classification",
            "unknown"
          ]
        }
      },
      "additionalProperties": false
    },
    "user_action_trace": {
      "type": "object",
      "properties": {
        "action_code": {
          "type": "string",
          "enum": [
            "none",
            "clicked_source",
            "refined_query",
            "saved_answer",
            "shared_answer",
            "rejected_answer",
            "requested_correction"
          ]
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": [
        "raw_query_stored",
        "raw_answer_stored",
        "personal_id_linked",
        "privacy_level",
        "retention_policy"
      ],
      "properties": {
        "raw_query_stored": {
          "type": "boolean",
          "const": false
        },
        "raw_answer_stored": {
          "type": "boolean",
          "const": false
        },
        "personal_id_linked": {
          "type": "boolean",
          "const": false
        },
        "privacy_level": {
          "type": "string",
          "enum": [
            "minimized",
            "aggregated",
            "anonymized",
            "review_required"
          ]
        },
        "retention_policy": {
          "type": "string",
          "enum": [
            "short_term",
            "aggregated_only",
            "delete_after_audit",
            "unspecified"
          ]
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "required": [
        "receipt_hash"
      ],
      "properties": {
        "receipt_hash": {
          "type": "string"
        },
        "previous_receipt_hash": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "properties": {
        "royalty_hook": {
          "type": "boolean"
        },
        "memory_hook": {
          "type": "boolean"
        },
        "rumination_hook": {
          "type": "boolean"
        },
        "human_review_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
